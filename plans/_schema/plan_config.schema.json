        "end_year"
      ],
      "title": "RampSpec",
      "type": "object"
    },
    "Ranges": {
      "additionalProperties": false,
      "description": "Year/age/YOS bounds for the simulation. Derived ranges\n(``entry_year_range``, ``age_range``, ``yos_range``,\n``max_year``, ``max_entry_year``) are computed properties.",
      "properties": {
        "max_age": {
          "title": "Max Age",
          "type": "integer"
        },
        "max_yos": {
          "default": 70,
          "title": "Max Yos",
          "type": "integer"
        },
        "min_age": {
          "title": "Min Age",
          "type": "integer"
        },
