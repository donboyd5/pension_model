              "const": "new_year",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Entry Year Min Param"
        },
        "fas_years": {
          "title": "Fas Years",
          "type": "integer"
        },
        "grandfathered_params": {
          "anyOf": [
            {
              "$ref": "#/$defs/GrandfatheredParams"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "not_grandfathered": {
          "default": false,
          "title": "Not Grandfathered",
