            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Entry Year Max"
        },
        "entry_year_max_param": {
          "anyOf": [
            {
              "const": "new_year",
              "type": "string"
            },
            {
              "type": "null"
